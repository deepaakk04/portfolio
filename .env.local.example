# .env.local
# Admin password for localhost-only admin panel
# IMPORTANT: This file should NEVER be committed to Git
ADMIN_PASSWORD=your_secure_password_here
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_REPO=your-username/blogs
# DEPLOY_HOOK replaces NETLIFY_BUILD_HOOK
DEPLOY_HOOK=https://api.vercel.com/hooks/deploy-queries/...
